{
  "input_csv": "data/messy_orders.csv",
  "encoding": "utf-8-sig",
  "delimiter": ",",
  "columns": ["order_id", "customer", "items", "notes", "total"],
  "defaults": {
    "notes": "",
    "total": "0.00"
  },
  "numeric_columns": ["total"],
  "output_dir": "out",
  "output_json": "orders.json",
  "output_jsonl": "orders.jsonl",
  "output_csv": "orders-clean.csv"
}
